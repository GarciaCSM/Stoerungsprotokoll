{
  "expo": {
    "name": "Störungsprotokoll",
    "slug": "stoerungsprotokoll",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/app-icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f1729"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-barcode-scanner"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stoerungsprotokoll.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Kamera wird zum Scannen von FA-Nummern auf Barcodes verwendet."
      }
    },
    "android": {
      "package": "com.stoerungsprotokoll.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#0f1729"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "extra": {
      "eas": {
        "projectId": "7d22cc24-504d-4eef-9d69-29bd649e022b"
      }
    }
  }
}
